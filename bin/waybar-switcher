#!/usr/bin/env bash

set -euo pipefail

# Script name : waybar-switcher
# Description: Switch between Waybar configuration using a symlink
# Dependencies: fzf, curl, pkill, waybar, uwsm-app (optional)

CONFIG_DIR="$HOME/.config/waybar-configs" # Directory containing all Waybar configs
WAYBAR_LINK="$HOME/.config/waybar" # Symlink used by Waybar

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

# Verify dependencies
for cmd in fzf curl pkill; do
  command -v "$cmd" &>/dev/null || { echo -e "${RED}${BOLD}[ERROR]${RESET} Dependency not found: $cmd"; exit 1; }
done

help() {
  cat <<'EOF'
waybar-switcher — switch and manage Waybar configurations

Usage:
  waybar-switcher [command]

Commands:
  (none)    Open fzf picker to select and switch to a Waybar config
  update    Pull and install the latest release from GitHub
  help      Show this help message

Examples:
  waybar-switcher             # open config picker

Paths:
  ~/.config/waybar-configs/       configs directory (one subdir per theme)
  ~/.config/waybar                symlink managed by this tool

Dependencies:
  fzf, curl, pkill, waybar, uwsm-app (optional)

Notes:
  - Each config must be a subdirectory inside ~/.config/waybar-configs/
  - Do not store files directly in ~/.config/waybar — it is a symlink
  - Waybar is automatically restarted after switching
EOF
}

switch_config() {
  # If config dir is missing, bootstrap it from the current waybar config
  if [[ ! -d "$CONFIG_DIR" ]]; then
    mkdir -p $CONFIG_DIR
    cp -rL "$WAYBAR_LINK" "$CONFIG_DIR/Default"
  fi

  # Display all available configurations through fzf
  selected_config=$(
    find "$CONFIG_DIR" \
      -mindepth 1 \
      -maxdepth 1 \
      -type d \
      -printf "%f\n" |
    sort |
    fzf \
      --prompt="Select Waybar configuration > " \
      --height=40% \
      --border \
      --reverse
  )

  # Exit if no configuration was selected
  [[ -z "$selected_config" ]] && exit 0

  # Remove the current symlink if it exists
  rm -rf "$WAYBAR_LINK"

  # Create a new symlink pointing to the selected config
  ln -s "$CONFIG_DIR/$selected_config" "$WAYBAR_LINK"

  # Reload Waybar
  pkill -9 -x waybar

  # Prefer uwsm-app if available (required for some compositors like Hyprland + UWSM)
  if command -v uwsm-app &>/dev/null; then
    setsid uwsm-app -- waybar >/dev/null 2>&1 &
  else
    setsid waybar >/dev/null 2>&1 &
  fi

  echo -e "${GREEN}${BOLD}[SUCCESS]${RESET} Waybar configuration switched to: $selected_config"
}

case "${1:-}" in
  help|--help|-h)
    help
    ;;
  *)
    switch_config
    ;;
esac
